# Default: normalize all text files to LF in the repo,
# check out as native on each platform
* text=auto

# ----- Windows scripts (MUST be CRLF — CMD requires it) -----
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# ----- Shell / cross-platform scripts (LF) ------------------
*.sh    text eol=lf
*.bash  text eol=lf
*.zsh   text eol=lf

# ----- Config / data files (LF) -----------------------------
*.conf  text eol=lf
*.cfg   text eol=lf
*.ini   text eol=lf
*.env   text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.toml  text eol=lf
*.json  text eol=lf
*.xml   text eol=lf

# ----- Markup / docs (LF) -----------------------------------
*.md    text eol=lf
*.txt   text eol=lf
*.rst   text eol=lf
*.html  text eol=lf
*.css   text eol=lf

# ----- Source code (LF) -------------------------------------
*.py    text eol=lf
*.js    text eol=lf
*.ts    text eol=lf
*.c     text eol=lf
*.cpp   text eol=lf
*.h     text eol=lf

# ----- Binary files (no line ending conversion) -------------
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.zip   binary
*.7z    binary
*.exe   binary
*.dll   binary
*.pdf   binary
